rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "GarrettLMiller@gmail.com" || 
         request.auth.token.email == "garrettlmiller@gmail.com" ||
         request.auth.uid == "ewHQJbPdJkVxa5Onn40JYcKoaj22");
    }

    // Chefs
    match /chefs/{chefId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Players
    match /players/{playerId} {
      allow read: if true;
      allow write: if isAdmin() || (isAuthenticated() && request.auth.uid == playerId);
    }

    // Score Events
    match /scoreEvents/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Config
    match /config/league {
      allow read: if true;
      allow update: if isAdmin() || (
        isAuthenticated() && 
        resource.data.draftStarted == false &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['draftOrder'])
      );
      allow create, delete: if isAdmin();
    }

    // Player Statuses
    match /playerStatuses/{statusId} {
      allow read: if true;
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.text is string &&
        request.resource.data.text.size() > 0 &&
        request.resource.data.text.size() < 500;
      allow update: if isAuthenticated() && 
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.text is string &&
        request.resource.data.text.size() > 0 &&
        request.resource.data.text.size() < 500;
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    // Polls
    match /polls/{pollId} {
      allow read: if true;
      allow create, delete: if isAuthenticated();
      allow update: if isAuthenticated();
    }
  }
}
